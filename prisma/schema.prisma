generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  description String?
  image       String?

  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")

  posts       Post[]
  position    Int        @default(0)
  createdAt   DateTime   @default(now())
}

model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?

  content     String
  editorType  String

  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])

  coverImage  String?
  type        String   @default("text")
  duration    String?

  tags        String?

  published   Boolean  @default(false)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GlossaryTerm {
  id         String   @id @default(cuid())
  term       String
  slug       String   @unique
  definition String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PageView {
  id    String @id @default(cuid())
  path  String
  date  String // "2025-03-03" (täglich gruppiert)
  count Int    @default(1)

  @@unique([path, date])
}
